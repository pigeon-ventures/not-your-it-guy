# Copy this file to .env and fill in values.
# .env is gitignored and should never be committed.

# Set to true to enable DEBUG-level console logging
DEBUG=false

# Port the app listens on (local dev only — Docker / Render override this)
PORT=8000

# Bearer token required on all /v1/* requests.
# Generate a strong random value, e.g.: openssl rand -hex 32
API_TOKEN=

# HTTP Basic Auth credentials for the frontend (GET /)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# OpenAI API key — used by the router service (intent classification) and subgraphs
OPENAI_API_KEY=

# PostgreSQL connection string
# Local dev (docker-compose): postgresql://mssvcacc:nyig_local@localhost:5432/msmock
# Render: inject the External Database URL from the Render dashboard
DATABASE_URL=postgresql://mssvcacc:nyig_local@localhost:5432/msmock

# docker-compose local DB password (matches POSTGRES_PASSWORD above)
DB_PASSWORD=nyig_local

# Resend API key — when set, welcome emails are sent via Resend
# Leave empty to log email content to console instead (local dev)
RESEND_API_KEY=
